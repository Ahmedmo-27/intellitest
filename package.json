{
  "name": "intellitest",
  "type": "module",
  "displayName": "intellitest",
  "description": "A VS Code extension that helps junior testers generate structured test cases by applying standard software testing techniques based on project context.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:intellitestView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "IntelliTest",
      "properties": {
        "intellitest.backendUrl": {
          "type": "string",
          "default": "http://localhost:3000",
          "description": "Base URL of the IntelliTest backend (no trailing slash). Must match Server/.env PORT — e.g. http://localhost:3001 when PORT=3001."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "intellitest-sidebar",
          "title": "IntelliTest",
          "icon": "media/intellitest.svg"
        }
      ]
    },
    "views": {
      "intellitest-sidebar": [
        {
          "type": "webview",
          "id": "intellitestView",
          "name": "IntelliTest"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "website": "node website-server.js"
    
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "express": "^4.21.2",
    "xlsx": "^0.18.5"
  }
}
