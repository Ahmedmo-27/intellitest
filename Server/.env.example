PORT=3000
NODE_ENV=development

# Optional: max characters per log section in the terminal (extension payload, LLM prompt, LLM response)
# LOG_MAX_SECTION_CHARS=80000

# LLM: "ollama" (local) or "api" (OpenAI-compatible — use with Groq below)
LLM_PROVIDER=api

# Ollama (when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Groq (OpenAI-compatible Chat Completions — when LLM_PROVIDER=api)
# Create a key at https://console.groq.com/keys
API_BASE_URL=https://api.groq.com/openai/v1
API_KEY=
# See https://console.groq.com/docs/models for current ids
API_MODEL=llama-3.3-70b-versatile
