PORT=3000
NODE_ENV=development

# LLM: "ollama" (local) or "api" (OpenAI-compatible HTTP API)
LLM_PROVIDER=ollama

# Ollama (default local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# External API (OpenAI-compatible: base URL without path, e.g. https://api.openai.com/v1)
API_BASE_URL=
API_KEY=
API_MODEL=gpt-4o-mini